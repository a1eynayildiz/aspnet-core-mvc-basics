@model dotnet_basics.Models.ViewModels.HomePageViewModel

<h1 class="mb-4">Hoşgeldiniz!</h1>

<h2>Öne Çıkan Kurslar</h2>
<div class="row">
    @foreach (var course in Model.Courses)
    {
        <div class="col-md-3">
            @await Html.PartialAsync("_CourseCard", course)
        </div>
    }
</div>

<a asp-controller="Course" asp-action="List" class="btn btn-outline-primary mt-2">
    Tüm Kursları Gör
</a>

<hr class="my-5" />

<h2>Popüler Ürünler</h2>
<div class="row">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-3">
            @await Html.PartialAsync("_ProductCard", product)
        </div>
    }
</div>

<a asp-controller="Products" asp-action="List" class="btn btn-outline-primary mt-2">
    Tüm Ürünleri Gör
</a>